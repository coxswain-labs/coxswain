{
  "name": "staging-ingress",
  "namespace": "staging",
  "status": "error",
  "class": "coxswain",
  "tls": [],
  "default_backend": null,
  "rules": [
    {
      "host": "staging.local",
      "paths": [
        {
          "path": "/",
          "path_type": "Prefix",
          "backend": {
            "service": "app",
            "port": "8080"
          }
        },
        {
          "path": "/api",
          "path_type": "Prefix",
          "backend": {
            "service": "app",
            "port": "8080"
          }
        }
      ]
    }
  ]
}
